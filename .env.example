# ============================================================
# AI DevOps Optimizer — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# Application
PORT=3000
NODE_ENV=development

# --- Security ---
# API Key Authentication (comma-separated list of valid keys)
# Leave empty to disable auth (open access for local development)
# API_KEYS=your-api-key-1,your-api-key-2

# --- LLM Provider (choose one) ---

# Option A: NVIDIA NIM (free tier) → https://build.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Option B: OpenAI
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# --- GitHub (required for /api/heal and CLI) ---
# GITHUB_TOKEN=ghp_your-token-here
# GITHUB_REPOSITORY_URL=https://github.com/your-org/your-repo

# --- Grafana (local development) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
